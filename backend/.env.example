# ARKAND CRM — backend окружение (§14: секреты только в env)
ENV=development

# БД: SQLite локально; на Railway укажите Postgres DATABASE_URL
DATABASE_URL=sqlite:///./arkand.db
AUTO_CREATE_TABLES=true

# Auth
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Realtime (необязательно локально; на Railway — Redis)
# REDIS_URL=redis://localhost:6379/0

# Порог крупного расхода — согласование троих (§8.2)
LARGE_EXPENSE_THRESHOLD=50000

# CORS (адрес фронта)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
